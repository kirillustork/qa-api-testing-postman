                  "});",
                  "",
                  "pm.test(\"Response is array\", function () {",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const requestedCategory = pm.request.url.query.get(\"category\");",
                  "",
                  "if (requestedCategory) {",
                  "    pm.test(\"All products match requested category\", function () {",
                  "        json.forEach(item => {",
                  "            pm.expect(item.category).to.eql(requestedCategory);",
                  "        });",
                  "    });",
                  "}",
                  "",
                  "const requestedManufacturer = pm.request.url.query.get(\"manufacturer\");",
