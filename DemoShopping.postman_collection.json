        {
          "name": "Добавление нового продукта",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Проверка статус-кода",
                  "pm.test(\"Successful POST request\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "// Получаем Content-Type",
                  "const contentType = pm.response.headers.get(\"Content-Type\");",
                  "",
                  "// Гибкая проверка Content-Type",
                  "pm.test(`Content-Type received: ${contentType}`, function () {",
                  "    pm.expect(contentType).to.exist;",
                  "});",
                  "",
                  "// Логика обработки ответа",
                  "if (contentType && contentType.includes(\"application/json\")) {",
                  "",
                  "    // Нормальный API режим",
                  "    const json = pm.response.json();",
                  "",
                  "    pm.test(\"Response contains product_id\", function () {",
                  "        pm.expect(json.product_id).to.exist;",
                  "    });",
                  "",
                  "    if (json.product_id) {",
                  "        pm.environment.set(\"product_id\", json.id);",
                  "        console.log(\"Saved id:\", json.id);",
                  "    }",
                  "",
                  "} else if (",
                  "    contentType &&",
                  "    (contentType.includes(\"text/plain\") || contentType.includes(\"text/html\"))",
                  ") {",
                  "",
                  "    // Учебный режим (сервер возвращает текст)",
                  "    const text = pm.response.text();",
                  "",
                  "    pm.test(\"Success message returned (text response)\", function () {",
                  "        pm.expect(text.toLowerCase()).to.include(\"успешно\");",
                  "    });",
                  "",
                  "    // Более точное извлечение ID",
                  "    const match = text.match(/ID:\\s*(\\d+)/i);",
                  "",
                  "    if (match && match[1]) {",
                  "        pm.environment.set(\"product_id\", match[1]);",
                  "        console.log(\"Saved id:\", match[1]);",
                  "    }",
                  "",
                  "} else {",
                  "",
                  "    // Полностью неожиданный формат",
                  "    pm.test(`Unsupported Content-Type: ${contentType}`, function () {",
                  "        pm.expect.fail(`API returned unsupported Content-Type: ${contentType}`);",
                  "    });",
                  "",
                  "}",
                  "",
                  "pm.test(\"Response time is less than 800ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(800);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
