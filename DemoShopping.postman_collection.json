        {
          "name": "Получение списка продуктов",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Проверка статус-кода",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Проверка типа данных в ответе",
                  "pm.test(\"Response is an array\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.be.an(\"array\");",
                  "});",
                  "",
                  "// Проверка, что в ответе не пустой массив",
                  "pm.test(\"Response array is not empty\", function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response.length).to.be.above(0);",
                  "});",
                  "",
                  "// Проверка структуры объекта",
                  "pm.test(\"Object has required fields\", function () {",
                  "    const item = pm.response.json()[0];",
                  "",
                  "    pm.expect(item).to.have.property(\"product_id\");",
                  "    pm.expect(item).to.have.property(\"name\");",
                  "    pm.expect(item).to.have.property(\"description\");",
                  "    pm.expect(item).to.have.property(\"price\");",
                  "    pm.expect(item).to.have.property(\"category\");",
                  "    pm.expect(item).to.have.property(\"manufacturer\");",
                  "    pm.expect(item).to.have.property(\"imageUrl\");",
                  "    pm.expect(item).to.have.property(\"freeShipping\");",
                  "});",
                  "",
                  "// Проверка типов данных",
                  "pm.test(\"Fields have correct data types\", function () {",
                  "    const item = pm.response.json()[0];",
                  "    //В Swagger schema используется \"id\", но API возвращает \"product_id\". Оставляю \"id\" для показа ошибки.",
                  "    pm.expect(item.id).to.be.a(\"number\");",
                  "    pm.expect(item.name).to.be.a(\"string\");",
                  "    pm.expect(item.description).to.be.a(\"string\");",
                  "    pm.expect(item.price).to.be.a(\"number\");",
                  "    pm.expect(item.category).to.be.a(\"string\");",
                  "    pm.expect(item.manufacturer).to.be.a(\"string\");",
                  "    pm.expect(item.imageUrl).to.be.a(\"string\");",
                  "    pm.expect(item.freeShipping).to.be.a(\"boolean\");",
                  "});",
                  "",
                  "// Проверка времени ответа",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "// Проверка, что цена больше или равна нулю",
                  "pm.test(\"Price is not negative\", function () {",
                  "    const item = pm.response.json()[0];",
                  "    pm.expect(item.price).to.be.at.least(0);",
                  "});",
                  "",
                  "// Проверка, что все продукты имеют уникальные ID",
                  "pm.test(\"IDs are unique\", function () {",
                  "    const response = pm.response.json();",
                  "    const ids = response.map(item => item.product_id);",
                  "    const uniqueIds = new Set(ids);",
                  "    pm.expect(uniqueIds.size).to.eql(ids.length);",
                  "});",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
